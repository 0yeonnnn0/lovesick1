# lovesick1 environment template
# 1. Copy this file to `.env`
# 2. Fill only one provider section: google / openai / anthropic / codex
# 3. Never commit the real `.env`

# ── Required: Discord bot ──────────────────────────────────────────────────────
DISCORD_TOKEN=YOUR_NEW_DISCORD_BOT_TOKEN
OWNER_ID=YOUR_DISCORD_USER_ID

# ── Required: dashboard / server ───────────────────────────────────────────────
DASHBOARD_PORT=3000
DASHBOARD_SECRET=CHANGE_THIS_TO_A_STRONG_SECRET

# ── Required: choose one AI provider ───────────────────────────────────────────
# Supported: google / openai / anthropic / codex
AI_PROVIDER=codex

# ── Recommended default: Codex CLI runtime ─────────────────────────────────────
# Requires:
# - `codex` CLI installed on the server or inside Docker image
# - logged-in auth at CODEX_AUTH_DIR/auth.json
# - trusted host / NAS environment
CODEX_BIN=codex
CODEX_MODEL=gpt-5.4
CODEX_AUTH_DIR=./.codex

# ── Alternative: Google Gemini ─────────────────────────────────────────────────
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash-lite

# ── Alternative: OpenAI API ────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── Alternative: Anthropic API ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Optional ───────────────────────────────────────────────────────────────────
# Obsidian-style vault root, if you want note sync.
VAULT_PATH=
